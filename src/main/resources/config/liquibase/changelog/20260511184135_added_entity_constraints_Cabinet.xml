<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">
    <!--
        Added the constraints for entity Cabinet.
    -->
    <changeSet id="20260511184135-2" author="jhipster">

        <addForeignKeyConstraint baseColumnNames="template_id"
                                 baseTableName="cabinet"
                                 constraintName="fk_cabinet__template_id"
                                 referencedColumnNames="id"
                                 referencedTableName="cabinet_template"
                                 />

        <addForeignKeyConstraint baseColumnNames="material_id"
                                 baseTableName="cabinet"
                                 constraintName="fk_cabinet__material_id"
                                 referencedColumnNames="id"
                                 referencedTableName="material"
                                 />

        <addForeignKeyConstraint baseColumnNames="spec_id"
                                 baseTableName="cabinet"
                                 constraintName="fk_cabinet__spec_id"
                                 referencedColumnNames="id"
                                 referencedTableName="kitchen_spec"
                                 />
    </changeSet>
</databaseChangeLog>
