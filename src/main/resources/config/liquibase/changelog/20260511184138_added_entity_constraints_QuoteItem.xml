<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">
    <!--
        Added the constraints for entity QuoteItem.
    -->
    <changeSet id="20260511184138-2" author="jhipster">

        <addForeignKeyConstraint baseColumnNames="cabinet_id"
                                 baseTableName="quote_item"
                                 constraintName="fk_quote_item__cabinet_id"
                                 referencedColumnNames="id"
                                 referencedTableName="cabinet"
                                 />

        <addForeignKeyConstraint baseColumnNames="hardware_id"
                                 baseTableName="quote_item"
                                 constraintName="fk_quote_item__hardware_id"
                                 referencedColumnNames="id"
                                 referencedTableName="hardware"
                                 />

        <addForeignKeyConstraint baseColumnNames="quote_id"
                                 baseTableName="quote_item"
                                 constraintName="fk_quote_item__quote_id"
                                 referencedColumnNames="id"
                                 referencedTableName="quote"
                                 />
    </changeSet>
</databaseChangeLog>
